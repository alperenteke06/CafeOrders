<Window x:Class="CafeManagement.Kiosk.MainWindow"
        x:Name="RootWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:primitives="clr-namespace:System.Windows.Controls.Primitives;assembly=PresentationFramework"
        xmlns:vm="clr-namespace:CafeManagement.Kiosk.ViewModels"
        mc:Ignorable="d"
        Title="CafeManagement Client"
        Icon="pack://application:,,,/Assets/app-icon.ico"
        Width="1600"
        Height="980"
        WindowState="Maximized"
        WindowStyle="None"
        ResizeMode="NoResize"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display"
        Background="{StaticResource BackgroundPrimaryBrush}">
    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Window.Resources>
        <Style x:Key="GhostIconButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="52" />
            <Setter Property="Height" Value="52" />
            <Setter Property="Background" Value="#1A2235" />
            <Setter Property="Foreground" Value="#F4D29A" />
            <Setter Property="BorderBrush" Value="#00000000" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="18">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="QuickAddIconButtonStyle" TargetType="Button" BasedOn="{StaticResource GhostIconButtonStyle}">
            <Setter Property="Background" Value="#121B2CDD" />
            <Setter Property="Foreground" Value="#FFB800" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid RenderTransformOrigin="0.5,0.5">
                            <Grid.RenderTransform>
                                <TranslateTransform x:Name="QuickAddLift" Y="0" />
                            </Grid.RenderTransform>
                            <Border x:Name="QuickAddAura"
                                    Opacity="0"
                                    Margin="-3"
                                    CornerRadius="21"
                                    Background="#18FFB800"
                                    BorderBrush="#38FFD57A"
                                    BorderThickness="1" />
                            <Border x:Name="QuickAddBorder" Background="{TemplateBinding Background}" CornerRadius="18">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="QuickAddAura" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.15" />
                                            <DoubleAnimation Storyboard.TargetName="QuickAddLift" Storyboard.TargetProperty="Y" To="-2" Duration="0:0:0.15" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="QuickAddAura" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.18" />
                                            <DoubleAnimation Storyboard.TargetName="QuickAddLift" Storyboard.TargetProperty="Y" To="0" Duration="0:0:0.18" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                                <Setter TargetName="QuickAddBorder" Property="Background" Value="#18243A" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="QuickAddBorder" Property="Background" Value="#0F1728" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="WindowButtonStyle" TargetType="Button" BasedOn="{StaticResource GhostIconButtonStyle}">
            <Setter Property="Width" Value="42" />
            <Setter Property="Height" Value="42" />
            <Setter Property="Background" Value="#121B2C" />
            <Setter Property="Foreground" Value="#E7D6B5" />
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#FFB800" />
            <Setter Property="Foreground" Value="#2F2200" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="24,16" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="18">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="MenuAddButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid RenderTransformOrigin="0.5,0.5">
                            <Grid.RenderTransform>
                                <TranslateTransform x:Name="MenuAddLift" Y="0" />
                            </Grid.RenderTransform>
                            <Border x:Name="MenuAddAura"
                                    Opacity="0"
                                    Margin="-3"
                                    CornerRadius="21"
                                    Background="#18FFB800"
                                    BorderBrush="#3DFFD57A"
                                    BorderThickness="1" />
                            <Border x:Name="MenuAddBorder" Background="{TemplateBinding Background}" CornerRadius="18">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}" />
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="MenuAddAura" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.15" />
                                            <DoubleAnimation Storyboard.TargetName="MenuAddLift" Storyboard.TargetProperty="Y" To="-2" Duration="0:0:0.15" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="MenuAddAura" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.18" />
                                            <DoubleAnimation Storyboard.TargetName="MenuAddLift" Storyboard.TargetProperty="Y" To="0" Duration="0:0:0.18" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                                <Setter TargetName="MenuAddBorder" Property="Background" Value="#FFC742" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="MenuAddBorder" Property="Background" Value="#E7A700" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="OutlineButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#E6DCC8" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="#49526A" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="18">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <ControlTemplate x:Key="CategoryButtonTemplate" TargetType="Button">
            <Grid RenderTransformOrigin="0.5,0.5">
                <Grid.RenderTransform>
                    <TranslateTransform x:Name="CategoryPillLift" Y="0" />
                </Grid.RenderTransform>
                <Border x:Name="CategoryHoverAura"
                        Opacity="0"
                        Margin="-4,4,-4,-4"
                        CornerRadius="29"
                        Background="#18FFB800"
                        BorderBrush="#42FFD57A"
                        BorderThickness="1" />
                <Border x:Name="CategoryPillBorder"
                        Background="{TemplateBinding Background}"
                        CornerRadius="25"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}">
                    <Grid Margin="18,0,18,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Ellipse x:Name="CategoryPillDot"
                                 Width="12"
                                 Height="12"
                                 Margin="0,0,12,0"
                                 Fill="#344561"
                                 VerticalAlignment="Center" />
                        <ContentPresenter Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Grid>
                </Border>
            </Grid>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="CategoryPillBorder" Property="BorderBrush" Value="#A88524" />
                    <Setter TargetName="CategoryPillBorder" Property="Background" Value="#22314B" />
                    <Setter Property="Foreground" Value="#FFF0CF" />
                    <Setter TargetName="CategoryPillDot" Property="Fill" Value="#FFB800" />
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="CategoryHoverAura"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="1"
                                                             Duration="0:0:0.16" />
                                            <DoubleAnimation Storyboard.TargetName="CategoryPillLift"
                                                             Storyboard.TargetProperty="Y"
                                                             To="0"
                                                             Duration="0:0:0.16" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                            <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="CategoryHoverAura"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="0"
                                                             Duration="0:0:0.18" />
                                            <DoubleAnimation Storyboard.TargetName="CategoryPillLift"
                                                             Storyboard.TargetProperty="Y"
                                                             To="0"
                                                             Duration="0:0:0.18" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter TargetName="CategoryPillBorder" Property="Background" Value="#182234" />
                    <Setter TargetName="CategoryPillBorder" Property="BorderBrush" Value="#7D6020" />
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <ControlTemplate x:Key="SelectedCategoryButtonTemplate" TargetType="Button">
            <Grid>
                <Border Background="{TemplateBinding Background}"
                        CornerRadius="25"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}">
                    <Grid Margin="18,0,18,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Ellipse Width="12"
                                 Height="12"
                                 Margin="0,0,12,0"
                                 Fill="#3A2900"
                                 VerticalAlignment="Center" />
                        <ContentPresenter Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Grid>
                </Border>
            </Grid>
        </ControlTemplate>

        <Style x:Key="CategoryButtonStyle" TargetType="Button">
            <Setter Property="Margin" Value="0,0,16,0" />
            <Setter Property="Padding" Value="26,14" />
            <Setter Property="MinWidth" Value="148" />
            <Setter Property="MinHeight" Value="50" />
            <Setter Property="Background" Value="#192338" />
            <Setter Property="Foreground" Value="#F0E5D0" />
            <Setter Property="BorderBrush" Value="#425373" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontSize" Value="17" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Template" Value="{StaticResource CategoryButtonTemplate}" />
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#08101F" Offset="0" />
                <GradientStop Color="#0C1424" Offset="1" />
            </LinearGradientBrush>
        </Grid.Background>

        <Grid Margin="28">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Text="{Binding CafeName}"
                           FontSize="30"
                           FontWeight="Bold"
                           Foreground="{StaticResource AccentBrush}"
                           VerticalAlignment="Center" />

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Margin="0,0,10,0"
                            Style="{StaticResource WindowButtonStyle}"
                            Click="MinimizeButton_OnClick">
                        <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE921;" FontSize="14" />
                    </Button>
                    <Button Margin="0,0,18,0"
                            Style="{StaticResource WindowButtonStyle}"
                            Click="CloseButton_OnClick">
                        <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE8BB;" FontSize="14" />
                    </Button>

                    <Border Margin="0,0,18,0" Padding="26,12" Background="#252E42" CornerRadius="16">
                        <TextBlock Text="{Binding DisplayTableName}"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource AccentBrush}" />
                    </Border>

                    <Grid>
                        <Button Style="{StaticResource GhostIconButtonStyle}"
                                Command="{Binding ToggleCartCommand}">
                            <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE7BF;" FontSize="22" />
                        </Button>
                        <Border Width="22"
                                Height="22"
                                Margin="36,-4,0,0"
                                Background="#F7D89F"
                                CornerRadius="11"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Top">
                            <TextBlock Text="{Binding CartItemCount}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       FontSize="11"
                                       FontWeight="Bold"
                                       Foreground="#1D2433" />
                        </Border>
                    </Grid>
                </StackPanel>
            </Grid>

            <Grid Grid.Row="1">
                <ScrollViewer x:Name="MenuViewRoot"
                              Visibility="{Binding IsMenuViewVisible, Converter={StaticResource BooleanToVisibilityConverter}}"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Opacity="1">
                    <StackPanel RenderTransformOrigin="0.5,0.5" Margin="0,0,0,18">
                        <StackPanel.RenderTransform>
                            <TranslateTransform x:Name="MenuViewTransform" />
                        </StackPanel.RenderTransform>

                        <Border Padding="28"
                                CornerRadius="24"
                                BorderThickness="1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="84" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border x:Name="InfoBoxIconBadge" Width="72" Height="72" CornerRadius="36">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#E4A900" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding InfoBoxType}" Value="Warning">
                                                    <Setter Property="Background" Value="#B63343" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding InfoBoxType}" Value="Success">
                                                    <Setter Property="Background" Value="#1B73BE" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="{Binding InfoBoxGlyph}" FontSize="28" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                                <StackPanel Grid.Column="1" Margin="18,0,0,0" VerticalAlignment="Center">
                                    <TextBlock x:Name="InfoBoxTypeText"
                                               Text="{Binding InfoBoxTypeLabel}"
                                               FontSize="16"
                                               FontWeight="SemiBold">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="#654A00" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding InfoBoxType}" Value="Warning">
                                                        <Setter Property="Foreground" Value="#FFE7E1" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding InfoBoxType}" Value="Success">
                                                        <Setter Property="Foreground" Value="#D9F4FF" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <TextBlock x:Name="InfoBoxMessageText"
                                               Text="{Binding InfoBoxMessage}"
                                               FontSize="18"
                                               FontWeight="Bold"
                                               TextWrapping="Wrap">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="#503900" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding InfoBoxType}" Value="Warning">
                                                        <Setter Property="Foreground" Value="#FFF5F2" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding InfoBoxType}" Value="Success">
                                                        <Setter Property="Foreground" Value="#F1FBFF" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                            </Grid>
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="{StaticResource AccentBrush}" />
                                    <Setter Property="BorderBrush" Value="#20FFE6B0" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding InfoBoxType}" Value="Warning">
                                            <Setter Property="Background" Value="#DB4B5A" />
                                            <Setter Property="BorderBrush" Value="#40FFB4AB" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding InfoBoxType}" Value="Success">
                                            <Setter Property="Background" Value="#2A93E8" />
                                            <Setter Property="BorderBrush" Value="#4033C9FF" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                        </Border>

                        <ScrollViewer Margin="0,26,0,22"
                                      HorizontalScrollBarVisibility="Auto"
                                      VerticalScrollBarVisibility="Disabled">
                            <StackPanel Orientation="Horizontal">
                                <Button Command="{Binding SelectCategoryCommand}">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource CategoryButtonStyle}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding DataContext.IsAllCategoriesSelected, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                                                    <Setter Property="Background" Value="{StaticResource AccentBrush}" />
                                                    <Setter Property="Foreground" Value="#3A2900" />
                                                    <Setter Property="BorderBrush" Value="#FFD57A" />
                                                    <Setter Property="Template" Value="{StaticResource SelectedCategoryButtonTemplate}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                    <Button.CommandParameter>
                                        <x:Null />
                                    </Button.CommandParameter>
                                    <TextBlock Text="Tumu" />
                                </Button>
                                <ItemsControl ItemsSource="{Binding Categories}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel Orientation="Horizontal" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Button Command="{Binding DataContext.SelectCategoryCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}"
                                                    Tag="{Binding IsSelected}">
                                                <Button.Style>
                                                    <Style TargetType="Button" BasedOn="{StaticResource CategoryButtonStyle}">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                                <Setter Property="Background" Value="{StaticResource AccentBrush}" />
                                                                <Setter Property="Foreground" Value="#3A2900" />
                                                                <Setter Property="BorderBrush" Value="#FFD57A" />
                                                                <Setter Property="Template" Value="{StaticResource SelectedCategoryButtonTemplate}" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>
                                                <TextBlock Text="{Binding Name}" />
                                            </Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </ScrollViewer>

                        <ItemsControl ItemsSource="{Binding VisibleProducts}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <primitives:UniformGrid Columns="4" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,22,24"
                                            Background="{StaticResource SurfaceBrush}"
                                            CornerRadius="24"
                                            BorderBrush="#243048"
                                            BorderThickness="1">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="240" />
                                                <RowDefinition Height="*" />
                                            </Grid.RowDefinitions>

                                            <Grid>
                                                <Border Background="#161F31" CornerRadius="24,24,0,0" />
                                                <Image Stretch="UniformToFill" Source="{Binding ImageUrl}">
                                                    <Image.Style>
                                                        <Style TargetType="Image">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding HasImage}" Value="True">
                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Image.Style>
                                                </Image>
                                                <Border Background="#121B2CDD" CornerRadius="24,24,0,0">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding HasImage}" Value="True">
                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding Name}"
                                                                   Foreground="{StaticResource AccentBrush}"
                                                                   FontWeight="Bold"
                                                                   FontSize="24"
                                                                   TextAlignment="Center"
                                                                   TextWrapping="Wrap"
                                                                   Margin="22" />
                                                    </StackPanel>
                                                </Border>

                                                    <Button Width="48"
                                                        Height="48"
                                                        Margin="0,16,16,0"
                                                        HorizontalAlignment="Right"
                                                        VerticalAlignment="Top"
                                                        Style="{StaticResource QuickAddIconButtonStyle}"
                                                        Command="{Binding DataContext.AddToCartCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                        CommandParameter="{Binding}">
                                                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE710;" FontSize="20" />
                                                </Button>
                                            </Grid>

                                            <Grid Grid.Row="1" Margin="24,20,24,24">
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="*" />
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>
                                                <TextBlock Text="{Binding Name}"
                                                           FontSize="19"
                                                           FontWeight="Bold"
                                                           Foreground="{StaticResource TextPrimaryBrush}"
                                                           TextWrapping="Wrap" />
                                                <TextBlock Grid.Row="1"
                                                           Margin="0,10,0,0"
                                                           Text="{Binding Description}"
                                                           Foreground="{StaticResource TextSecondaryBrush}"
                                                           TextWrapping="Wrap"
                                                           FontSize="16" />
                                                <Grid Grid.Row="2" Margin="0,20,0,0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="{Binding Price, StringFormat={}{0:N2} TL}"
                                                               Foreground="{StaticResource AccentBrush}"
                                                               FontSize="18"
                                                               FontWeight="Bold"
                                                               VerticalAlignment="Center" />
                                                    <Button Grid.Column="1"
                                                            MinWidth="98"
                                                            Style="{StaticResource MenuAddButtonStyle}"
                                                            Command="{Binding DataContext.AddToCartCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                            CommandParameter="{Binding}">
                                                        <TextBlock Text="Ekle" FontSize="16" />
                                                    </Button>
                                                </Grid>
                                            </Grid>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>

                <ScrollViewer x:Name="OrderViewRoot"
                              Visibility="{Binding IsOrderStatusVisible, Converter={StaticResource BooleanToVisibilityConverter}}"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Opacity="0">
                    <StackPanel HorizontalAlignment="Center" MaxWidth="1060" Margin="0,0,0,42">
                        <StackPanel.RenderTransform>
                            <TranslateTransform x:Name="OrderViewTransform" Y="18" />
                        </StackPanel.RenderTransform>

                        <StackPanel Margin="0,20,0,0" HorizontalAlignment="Center">
                            <Grid Width="300" Height="300">
                                <Ellipse Fill="#252525" />
                                <Ellipse Margin="30" Stroke="{StaticResource AccentBrush}" StrokeThickness="5" />
                                <TextBlock Text="🍽"
                                           FontSize="84"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Foreground="{StaticResource AccentBrush}" />
                                <Border VerticalAlignment="Bottom"
                                        HorizontalAlignment="Center"
                                        Margin="0,0,0,4"
                                        Padding="28,10"
                                        Background="{StaticResource AccentBrush}"
                                        CornerRadius="18">
                                    <TextBlock Text="{Binding ActiveOrderNumber, StringFormat=#\{0:0000\}}" FontSize="24" Foreground="#312100" />
                                </Border>
                            </Grid>

                            <TextBlock Margin="0,34,0,0"
                                       Text="{Binding ActiveOrderTitle}"
                                       FontSize="56"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource AccentBrush}"
                                       HorizontalAlignment="Center"
                                       TextAlignment="Center" />
                            <TextBlock Margin="0,12,0,0"
                                       Text="{Binding ActiveOrderMessage}"
                                       FontSize="22"
                                       Foreground="#D7CCB6"
                                       TextWrapping="Wrap"
                                       TextAlignment="Center"
                                       HorizontalAlignment="Center" />
                        </StackPanel>

                        <Border Margin="0,44,0,0"
                                Padding="34"
                                Background="{StaticResource SurfaceBrush}"
                                BorderBrush="#7B6125"
                                BorderThickness="1"
                                CornerRadius="24">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="96" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border Width="84" Height="84" Background="{StaticResource AccentBrush}" CornerRadius="20">
                                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE823;" FontSize="34" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                                <StackPanel Grid.Column="1" Margin="24,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="SIPARIS DURUMU" FontSize="16" Foreground="#C7B18A" />
                                    <TextBlock Text="{Binding ActiveOrderEtaText}"
                                               FontSize="26"
                                               FontWeight="SemiBold"
                                               Foreground="#FFE1A9"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Grid Margin="0,34,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.55*" />
                                <ColumnDefinition Width="1*" />
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0"
                                    Margin="0,0,24,0"
                                    Padding="30"
                                    Background="{StaticResource SurfaceBrush}"
                                    BorderBrush="#374056"
                                    BorderThickness="1"
                                    CornerRadius="24">
                                <StackPanel>
                                    <TextBlock Text="Siparis Detaylari"
                                               FontSize="24"
                                               FontWeight="Bold"
                                               Foreground="{StaticResource TextPrimaryBrush}" />
                                    <ItemsControl Margin="0,24,0,0" ItemsSource="{Binding ActiveOrderLines}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Margin="0,0,0,18">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="{Binding Quantity, StringFormat={}{0}x}"
                                                               Margin="0,0,14,0"
                                                               FontSize="16"
                                                               FontWeight="Bold"
                                                               Foreground="#FFE1A9" />
                                                    <TextBlock Grid.Column="1"
                                                               Text="{Binding Name}"
                                                               FontSize="18"
                                                               Foreground="{StaticResource TextPrimaryBrush}"
                                                               TextWrapping="Wrap" />
                                                    <TextBlock Grid.Column="2"
                                                               Text="{Binding Total, StringFormat={}{0:N2} TL}"
                                                               FontSize="18"
                                                               Foreground="#E7C997" />
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <Border Margin="0,8,0,0" Height="1" Background="#2F384D" />
                                    <Grid Margin="0,18,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Toplam Tutar" FontSize="18" Foreground="{StaticResource TextPrimaryBrush}" />
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding ActiveOrderTotal, StringFormat={}{0:N2} TL}"
                                                   FontSize="22"
                                                   FontWeight="Bold"
                                                   Foreground="{StaticResource AccentBrush}" />
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="1"
                                    Padding="28"
                                    Background="{StaticResource SurfaceBrush}"
                                    BorderBrush="#374056"
                                    BorderThickness="1"
                                    CornerRadius="24">
                                <StackPanel>
                                    <TextBlock Text="Oyun keyfiniz bolunmesin!"
                                               FontSize="24"
                                               FontWeight="Bold"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               TextWrapping="Wrap" />
                                    <TextBlock Margin="0,16,0,0"
                                               Text="Siparisiniz hazirlanirken oyununuzun keyfini cikarmaya devam edin. Guncel durum burada otomatik yenilenir."
                                               FontSize="18"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               TextWrapping="Wrap" />
                                    <Border Margin="0,28,0,0"
                                            Padding="18"
                                            Background="#131B2CDD"
                                            CornerRadius="18">
                                        <StackPanel>
                                            <TextBlock Text="{Binding ActiveOrderBannerTitle}"
                                                       FontSize="18"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource AccentBrush}" />
                                            <TextBlock Margin="0,10,0,0"
                                                       Text="{Binding ActiveOrderBannerMessage}"
                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <Button Margin="0,38,0,88"
                                Width="260"
                                MinHeight="60"
                                HorizontalAlignment="Center"
                                Style="{StaticResource OutlineButtonStyle}"
                                Command="{Binding ReturnToMenuCommand}">
                            <TextBlock Text="Menuye Don" FontSize="18" />
                        </Button>
                    </StackPanel>
                </ScrollViewer>
            </Grid>

            <Grid Grid.Row="2" Margin="0,12,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="{Binding FooterCopyrightText}"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
                    <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                        <TextBlock Text="YAZILIM GELISTIRICI"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   HorizontalAlignment="Right" />
                        <Border Width="96"
                                Height="1"
                                Margin="0,4,0,6"
                                Background="#46FFB800"
                                HorizontalAlignment="Right" />
                        <TextBlock Text="{Binding AppDeveloperName}"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource AccentBrush}"
                                   HorizontalAlignment="Right" />
                        <TextBlock Text="{Binding AppDeveloperPhone}"
                                   FontSize="15"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   HorizontalAlignment="Right" />
                    </StackPanel>
                </Grid>
            </Grid>
        </Grid>

        <Border x:Name="CartOverlay"
                Background="#88050816"
                Opacity="0"
                Visibility="Collapsed"
                Panel.ZIndex="30"
                MouseDown="CartOverlay_OnMouseDown" />

        <Border x:Name="CartDrawer"
                Width="520"
                HorizontalAlignment="Right"
                Margin="0,0,0,0"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="#2B3550"
                BorderThickness="1,0,0,0"
                Panel.ZIndex="40"
                Visibility="Collapsed">
            <Border.RenderTransform>
                <TranslateTransform x:Name="CartDrawerTransform" X="560" />
            </Border.RenderTransform>

            <Grid Margin="28,24,28,24">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🧺" FontSize="24" Margin="0,0,12,0" />
                        <TextBlock Text="Sepetim" FontSize="22" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}" />
                    </StackPanel>
                    <Button Grid.Column="1"
                            Style="{StaticResource GhostIconButtonStyle}"
                            Width="46"
                            Height="46"
                            Background="#00000000"
                            Foreground="#DCCCB0"
                            Command="{Binding CloseCartCommand}">
                        <TextBlock Text="✕" FontSize="18" />
                    </Button>
                </Grid>

                <Border Grid.Row="1"
                        Margin="0,22,0,0"
                        Padding="18"
                        Background="#232D40"
                        CornerRadius="18"
                        BorderBrush="#2D3A55"
                        BorderThickness="1">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE73E;" FontSize="18" Foreground="#2FD6FF" Margin="0,0,12,0" />
                        <StackPanel>
                            <TextBlock Text="{Binding ActiveOrderBannerTitle}" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" />
                            <TextBlock Text="{Binding ActiveOrderBannerMessage}" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <ScrollViewer Grid.Row="2" Margin="0,24,0,24" VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding Cart}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,0,18" Padding="18" Background="{StaticResource PanelBrush}" CornerRadius="22">
                                    <Grid>
                                        <Button Width="36"
                                                Height="36"
                                                HorizontalAlignment="Right"
                                                VerticalAlignment="Top"
                                                Style="{StaticResource GhostIconButtonStyle}"
                                                Padding="0"
                                                Background="#2A2330"
                                                Foreground="#F0B7B0"
                                                Command="{Binding DataContext.RemoveCartItemCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}">
                                            <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE74D;" FontSize="14" />
                                        </Button>

                                        <Grid Margin="0,0,56,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="112" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                        <Grid Width="96" Height="96">
                                            <Border Background="#1C2538" CornerRadius="18" />
                                            <Image Stretch="UniformToFill" Source="{Binding ImageUrl}">
                                                <Image.Style>
                                                    <Style TargetType="Image">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding HasImage}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Image.Style>
                                            </Image>
                                            <TextBlock Text="{Binding Name}"
                                                       Foreground="{StaticResource AccentBrush}"
                                                       TextWrapping="Wrap"
                                                       TextAlignment="Center"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       Margin="12">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding HasImage}" Value="True">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Grid>

                                            <Grid Grid.Column="1" Margin="16,0,0,0" VerticalAlignment="Center">
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>

                                                <TextBlock Text="{Binding Name}"
                                                           FontSize="18"
                                                           FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextPrimaryBrush}"
                                                           TextTrimming="CharacterEllipsis" />
                                                <TextBlock Grid.Row="1"
                                                           Text="{Binding Quantity, StringFormat={}{0} Adet}"
                                                           Margin="0,6,0,16"
                                                           Foreground="{StaticResource TextSecondaryBrush}" />
                                                <Grid Grid.Row="2">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>

                                                    <Border Width="206"
                                                            Height="56"
                                                            Background="#34415D"
                                                            CornerRadius="28"
                                                            BorderBrush="#5A6B8B"
                                                            BorderThickness="1"
                                                            SnapsToDevicePixels="True">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="54" />
                                                                <ColumnDefinition Width="1" />
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="1" />
                                                                <ColumnDefinition Width="54" />
                                                            </Grid.ColumnDefinitions>

                                                            <Button Grid.Column="0"
                                                                    Width="46"
                                                                    Height="46"
                                                                    Margin="5,5,0,5"
                                                                    Background="#4B5774"
                                                                    BorderThickness="0"
                                                                    Cursor="Hand"
                                                                    Padding="0"
                                                                    HorizontalAlignment="Left"
                                                                    VerticalAlignment="Center"
                                                                    Command="{Binding DataContext.DecreaseQuantityCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                    CommandParameter="{Binding}">
                                                                <Button.Template>
                                                                    <ControlTemplate TargetType="Button">
                                                                        <Border Background="{TemplateBinding Background}" CornerRadius="18">
                                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                                        </Border>
                                                                    </ControlTemplate>
                                                                </Button.Template>
                                                                <TextBlock Text="−" FontSize="19" FontWeight="SemiBold" Foreground="#F2E1BE" />
                                                            </Button>

                                                            <Border Grid.Column="1"
                                                                    Width="1"
                                                                    Margin="0,14,0,14"
                                                                    Background="#60708F"
                                                                    Opacity="0.55" />

                                                            <Border Grid.Column="2"
                                                                    Margin="8,7"
                                                                    Background="#28334D"
                                                                    CornerRadius="16"
                                                                    BorderBrush="#43516F"
                                                                    BorderThickness="1">
                                                                <TextBlock Text="{Binding Quantity}"
                                                                           HorizontalAlignment="Center"
                                                                           VerticalAlignment="Center"
                                                                           FontSize="21"
                                                                           FontWeight="Bold"
                                                                           Foreground="{StaticResource TextPrimaryBrush}" />
                                                            </Border>

                                                            <Border Grid.Column="3"
                                                                    Width="1"
                                                                    Margin="0,14,0,14"
                                                                    Background="#60708F"
                                                                    Opacity="0.55" />

                                                            <Button Grid.Column="4"
                                                                    Width="46"
                                                                    Height="46"
                                                                    Margin="0,5,5,5"
                                                                    Background="{StaticResource AccentBrush}"
                                                                    BorderThickness="0"
                                                                    Cursor="Hand"
                                                                    Padding="0"
                                                                    HorizontalAlignment="Right"
                                                                    VerticalAlignment="Center"
                                                                    Command="{Binding DataContext.IncreaseQuantityCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                    CommandParameter="{Binding}">
                                                                <Button.Template>
                                                                    <ControlTemplate TargetType="Button">
                                                                        <Border Background="{TemplateBinding Background}" CornerRadius="18">
                                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                                        </Border>
                                                                    </ControlTemplate>
                                                                </Button.Template>
                                                                <TextBlock Text="+" FontSize="20" FontWeight="Bold" Foreground="#2F2200" />
                                                            </Button>
                                                        </Grid>
                                                    </Border>

                                                    <TextBlock Grid.Column="1"
                                                               Margin="18,0,0,0"
                                                               VerticalAlignment="Center"
                                                               HorizontalAlignment="Right"
                                                               Text="{Binding Total, StringFormat={}{0:N2} TL}"
                                                               FontSize="18"
                                                               FontWeight="Bold"
                                                               Foreground="{StaticResource AccentBrush}" />
                                                </Grid>
                                            </Grid>
                                        </Grid>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <StackPanel Grid.Row="3">
                    <Grid Margin="0,0,0,18">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Toplam Tutar" FontSize="18" Foreground="{StaticResource TextPrimaryBrush}" />
                        <TextBlock Grid.Column="1"
                                   Text="{Binding CartTotal, StringFormat={}{0:N2} TL}"
                                   FontSize="24"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource AccentBrush}" />
                    </Grid>

                    <Button Style="{StaticResource PrimaryButtonStyle}"
                            Command="{Binding SubmitOrderCommand}"
                            IsEnabled="{Binding HasItemsInCart}">
                        <TextBlock Text="Siparisi Onayla" FontSize="18" />
                    </Button>

                    <Button Margin="0,14,0,0"
                            Style="{StaticResource OutlineButtonStyle}"
                            Command="{Binding ClearCartCommand}"
                            IsEnabled="{Binding HasItemsInCart}">
                        <TextBlock Text="Sepeti Temizle" FontSize="17" />
                    </Button>

                    <TextBlock Margin="0,14,0,0"
                               Text="{Binding DisplayTableName, StringFormat=Siparisiniz otomatik olarak {0} hesabina eklenecektir.}"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               TextWrapping="Wrap"
                               FontSize="14" />
                </StackPanel>
            </Grid>
        </Border>

        <Border Background="#D9050816"
                Panel.ZIndex="99"
                Visibility="{Binding IsBlockingOverlayVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Grid>
                <Border Width="560"
                        Padding="36"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        CornerRadius="28"
                        Background="#111827"
                        BorderBrush="#30FFB800"
                        BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="{Binding BlockingTitle}"
                                   FontSize="34"
                                   FontWeight="Bold"
                                   Foreground="White"
                                   HorizontalAlignment="Center" />
                        <TextBlock Margin="0,16,0,0"
                                   Text="{Binding StatusText}"
                                   TextWrapping="Wrap"
                                   TextAlignment="Center"
                                   Foreground="{StaticResource AccentBrush}"
                                   FontSize="18" />
                        <Border Margin="0,24,0,0"
                                Padding="18"
                                CornerRadius="18"
                                Background="#1A2235">
                            <StackPanel>
                                <TextBlock Text="Bu ekran cihaz yonetici tarafindan onaylanana kadar kilitli kalir."
                                           Foreground="White"
                                           FontWeight="SemiBold"
                                           TextAlignment="Center" />
                                <TextBlock Margin="0,10,0,0"
                                           Text="Onay geldiginde siparis ekrani otomatik olarak acilacaktir."
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           TextAlignment="Center"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Border Panel.ZIndex="120"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Margin="0,96,28,0"
                Padding="18"
                CornerRadius="22"
                BorderBrush="#26FFFFFF"
                BorderThickness="1"
                Visibility="{Binding IsStatusPopupVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Background" Value="#1B2438" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding StatusPopupTone}" Value="success">
                            <Setter Property="Background" Value="#143224" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding StatusPopupTone}" Value="warning">
                            <Setter Property="Background" Value="#432024" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <StackPanel Width="340">
                <TextBlock Text="{Binding StatusPopupTitle}" FontSize="20" FontWeight="Bold" Foreground="White" />
                <TextBlock Margin="0,8,0,0" Text="{Binding StatusPopupMessage}" TextWrapping="Wrap" Foreground="{StaticResource TextPrimaryBrush}" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
