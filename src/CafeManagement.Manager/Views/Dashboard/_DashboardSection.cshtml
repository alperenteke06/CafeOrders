@model CafeManagement.Manager.Models.DashboardViewModel
@{
    var allOrders = Model.RecentOrders.OrderByDescending(x => x.CreatedAt).ToArray();
    var completedOrders = allOrders.Where(x => x.Status == "Completed").ToArray();
    var revenue = completedOrders.Sum(x => x.TotalPrice);
    var productUsage = allOrders
        .SelectMany(x => x.Lines)
        .GroupBy(x => x.ProductName)
        .Select(x => new { Name = x.Key, Quantity = x.Sum(line => line.Quantity) })
        .OrderByDescending(x => x.Quantity)
        .FirstOrDefault();
    var recentOrders = allOrders.Take(5).ToArray();

    var now = DateTime.UtcNow;
    var currentHour = new DateTime(now.Year, now.Month, now.Day, now.Hour, 0, 0, DateTimeKind.Utc);
    var slots = Model.SelectedRange switch
    {
        "1a" => Enumerable.Range(0, 30)
            .Select(offset =>
            {
                var dayStart = now.Date.AddDays(-(29 - offset));
                var dayEnd = dayStart.AddDays(1);
                var slotOrders = allOrders.Where(order => order.CreatedAt >= dayStart && order.CreatedAt < dayEnd).ToArray();
                return new
                {
                    Label = $"{dayStart.ToLocalTime():dd MMM} - {dayEnd.AddSeconds(-1).ToLocalTime():dd MMM}",
                    ShortLabel = dayStart.ToLocalTime().ToString("dd MMM"),
                    Count = slotOrders.Length,
                    Tooltip = slotOrders.Select(order => $"Masa {order.TableId}: {string.Join(", ", order.Lines.Select(line => $"{line.Quantity}x {line.ProductName}"))}").ToArray()
                };
            })
            .ToArray(),
        "1h" => Enumerable.Range(0, 7)
            .Select(offset =>
            {
                var dayStart = now.Date.AddDays(-(6 - offset));
                var dayEnd = dayStart.AddDays(1);
                var slotOrders = allOrders.Where(order => order.CreatedAt >= dayStart && order.CreatedAt < dayEnd).ToArray();
                return new
                {
                    Label = $"{dayStart.ToLocalTime():dd.MM} - {dayEnd.AddSeconds(-1).ToLocalTime():dd.MM}",
                    ShortLabel = dayStart.ToLocalTime().ToString("ddd"),
                    Count = slotOrders.Length,
                    Tooltip = slotOrders.Select(order => $"Masa {order.TableId}: {string.Join(", ", order.Lines.Select(line => $"{line.Quantity}x {line.ProductName}"))}").ToArray()
                };
            })
            .ToArray(),
        _ => Enumerable.Range(0, 24)
            .Select(offset =>
            {
                var hourStart = currentHour.AddHours(-(23 - offset));
                var hourEnd = hourStart.AddHours(1);
                var slotOrders = allOrders.Where(order => order.CreatedAt >= hourStart && order.CreatedAt < hourEnd).ToArray();
                return new
                {
                    Label = $"{hourStart.ToLocalTime():HH\\:00} - {hourEnd.ToLocalTime():HH\\:00}",
                    ShortLabel = $"{hourStart.ToLocalTime():HH\\:00}",
                    Count = slotOrders.Length,
                    Tooltip = slotOrders.Select(order => $"Masa {order.TableId}: {string.Join(", ", order.Lines.Select(line => $"{line.Quantity}x {line.ProductName}"))}").ToArray()
                };
            })
            .ToArray()
    };

    var maxCount = Math.Max(1, slots.Max(x => x.Count));
    var chartTrackWidth = Math.Max(920, slots.Length * 74);
    var yAxis = Enumerable.Range(0, 5)
        .Select(step => (int)Math.Ceiling(maxCount * (4 - step) / 4d))
        .Distinct()
        .ToArray();
}

<section class="content-section section-enter">
    <div class="section-head">
        <div>
            <h2>Gelir ve Analiz</h2>
            <p>@(Model.SelectedRange == "1a" ? "Son 1 ay" : Model.SelectedRange == "1h" ? "Son 1 hafta" : "Son 1 gun") icin operasyon ozetleri.</p>
        </div>

        <div class="section-pills">
            <button class="category-pill @(Model.SelectedRange == "1g" ? "active" : string.Empty)" type="button" onclick="loadSection('dashboard', true, { range: '1g' })">1G</button>
            <button class="category-pill @(Model.SelectedRange == "1h" ? "active" : string.Empty)" type="button" onclick="loadSection('dashboard', true, { range: '1h' })">1H</button>
            <button class="category-pill @(Model.SelectedRange == "1a" ? "active" : string.Empty)" type="button" onclick="loadSection('dashboard', true, { range: '1a' })">1A</button>
        </div>
    </div>

    <div class="stats-grid">
        <article class="stats-card">
            <div class="stats-label">Secili Aralik Geliri</div>
            <div class="stats-value accent">@revenue.ToString("C0")</div>
            <div class="stats-note positive">@completedOrders.Length tamamlanan siparis</div>
        </article>

        <article class="stats-card">
            <div class="stats-label">Bekleyen Siparis</div>
            <div class="stats-value">@allOrders.Count(x => x.Status == "Pending")</div>
            <div class="stats-note positive">@Model.Snapshot.Stats.OnlineDevices cihaz cevrimici</div>
        </article>

        <article class="stats-card">
            <div class="stats-label">En Cok Tercih Edilen Urun</div>
            <div class="stats-value accent">@(productUsage?.Name ?? "Veri yok")</div>
            <div class="stats-note">@(productUsage is null ? "Yeterli siparis verisi yok" : $"{productUsage.Quantity} adet siparis edildi")</div>
        </article>
    </div>

    <div class="dashboard-grid">
        <article class="panel-card chart-card">
            <div class="panel-title-row">
                <div>
                    <h3>Saatlik Siparis Adedi</h3>
                    <p class="chart-subtitle">Grafik secili araliktaki siparis adetlerini ve hover icinde siparis icerigini gosterir.</p>
                </div>
            </div>

            <div class="chart-layout">
                <div class="chart-y-axis">
                    @foreach (var tick in yAxis)
                    {
                        <span>@tick</span>
                    }
                </div>

                <div class="chart-main">
                    <div class="chart-shell-scroll">
                        <div class="chart-track" style="width:@(chartTrackWidth)px;">
                            <div class="chart-shell interactive wide">
                                @foreach (var slot in slots)
                                {
                                    var heightPercent = maxCount == 0 ? 4 : Math.Max(6, slot.Count * 100 / maxCount);
                                    var tooltip = slot.Tooltip.Any() ? string.Join(" | ", slot.Tooltip) : "Siparis yok";
                                    <button class="chart-column interactive @(slot.Count == maxCount ? "active" : string.Empty)"
                                            type="button"
                                            style="height:@heightPercent%;"
                                            data-tooltip-title="@slot.Label"
                                            data-tooltip-content="@tooltip"
                                            onmouseenter="showChartTooltip(event)"
                                            onmouseleave="hideChartTooltip()">
                                        <span class="chart-column-count">@slot.Count</span>
                                    </button>
                                }
                            </div>

                            <div class="chart-axis tight wide">
                                @foreach (var slot in slots)
                                {
                                    <span>@slot.ShortLabel</span>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </article>

        <article class="panel-card activity-card">
            <div class="panel-title-row">
                <h3>Son Islemler</h3>
                <button class="link-button" type="button" onclick="loadSection('orders', true)">Tumunu Gor</button>
            </div>

            <div class="activity-list">
                @foreach (var order in recentOrders)
                {
                    <div class="activity-row">
                        <div class="activity-icon">@order.TableId</div>
                        <div class="activity-copy">
                            <strong>Masa @order.TableId</strong>
                            <span>@order.CreatedAt.ToLocalTime().ToString("dd.MM HH:mm")</span>
                        </div>
                        <div class="activity-amount">
                            <strong>@order.TotalPrice.ToString("C0")</strong>
                            <span>@order.Status</span>
                        </div>
                    </div>
                }
            </div>
        </article>
    </div>
</section>
