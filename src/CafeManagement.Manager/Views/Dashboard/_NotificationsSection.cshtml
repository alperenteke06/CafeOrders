@model CafeManagement.Manager.Models.DashboardViewModel
@{
    const int pageSize = 10;
    var totalPages = Math.Max(1, (int)Math.Ceiling(Model.Notifications.Count / (double)pageSize));
    var currentPage = Math.Min(Model.CurrentPage, totalPages);
    var items = Model.Notifications.Skip((currentPage - 1) * pageSize).Take(pageSize).ToArray();
    var visiblePages = Enumerable.Range(1, totalPages).Where(pageNumber => pageNumber == 1 || pageNumber == totalPages || Math.Abs(pageNumber - currentPage) <= 1).ToArray();
}

<section class="content-section section-enter">
    <div class="section-head">
        <div>
            <h2>Bildirimler</h2>
            <p>Son tamamlanan siparisler ve admin aksiyon gecmisi.</p>
        </div>
    </div>

    <div class="list-card-stack">
        @foreach (var item in items)
        {
            <article class="wide-table-card card-hover-rise"
                     data-status="@item.Status"
                     data-notification-order="@item.OrderId"
                     data-notification-title="@item.Title"
                     data-notification-meta="@item.Meta"
                     data-notification-amount="@item.Amount"
                     data-notification-status="@item.Status">
                <div class="wide-table-main">
                    <div class="device-square">
                        <span class="material-symbols-outlined">@(item.Status == "Pending" ? "notifications_active" : item.Status == "Rejected" ? "cancel" : item.Status == "Accepted" ? "task_alt" : "done_all")</span>
                    </div>
                    <div class="wide-device-copy">
                        <strong>@item.Title</strong>
                        <span>@item.Meta</span>
                    </div>
                    <div class="wide-device-notification-meta">
                        <div class="wide-device-badge @(item.Status == "Rejected" ? "dead" : item.Status == "Pending" ? "waiting" : "live")">@item.Amount</div>
                        <button class="notification-link-button notification-link-button-inline" type="button" onclick="goToNotificationOrder(@item.OrderId)">Kayda Git</button>
                    </div>
                </div>
            </article>
        }

        @if (!items.Any())
        {
            <article class="wide-table-card">
                <div class="wide-device-copy">
                    <strong>Bildirim yok</strong>
                    <span>Henuz tamamlanan siparis kaydi bulunmuyor.</span>
                </div>
            </article>
        }
    </div>

    <div class="pagination-pillbar">
        <button class="pagination-nav" type="button" @(currentPage <= 1 ? "disabled" : null) onclick="loadSection('notifications', true, { page: @(currentPage - 1), search: getSearchValue() }, true)">Onceki</button>
        @foreach (var pageNumber in visiblePages)
        {
            <button class="pagination-page @(pageNumber == currentPage ? "active" : string.Empty)" type="button" onclick="loadSection('notifications', true, { page: @(pageNumber), search: getSearchValue() }, true)">@pageNumber</button>
        }
        <button class="pagination-nav" type="button" @(currentPage >= totalPages ? "disabled" : null) onclick="loadSection('notifications', true, { page: @(currentPage + 1), search: getSearchValue() }, true)">Sonraki</button>
        <span class="pagination-summary">@items.Length / @Model.Notifications.Count kayit gosteriliyor</span>
    </div>
</section>
