        async function loadSoundFile(file) {
            if (!file.type.startsWith('audio/')) {
                showToast('Lutfen gecerli bir ses dosyasi secin.', 'warning');
                return;
            }

            if (file.size > 10 * 1024 * 1024) {
                showToast('Ses dosyasi 10MB sinirini asmamali.', 'warning');
                return;
            }

            const localPreviewUrl = URL.createObjectURL(file);
            updateSoundMedia(localPreviewUrl, file.name);

            const uploaded = await uploadSoundFile(file);
            if (!uploaded) {
                return;
            }

            const urlInput = document.getElementById('newOrderSoundUrl');
            const audio = document.getElementById('newOrderAudio');
            if (urlInput) {
                urlInput.value = uploaded.url ?? '';
            }
            if (audio) {
                audio.dataset.soundUrl = uploaded.url ?? '';
            }
            updateSoundMedia(uploaded.url ?? '', uploaded.fileName ?? file.name);
            showToast('Ses dosyasi yuklendi ve kayda hazir.', 'success');
        }

        async function uploadSoundFile(file) {
            const formData = new FormData();
            formData.append('file', file);

            try {
                const response = await fetch('/dashboard/settings/upload-sound', {
                    method: 'POST',
                    body: formData
                });

                if (!response.ok) {
                    throw new Error(await resolveErrorMessage(response, 'Ses dosyasi yuklenemedi.'));
                }

                return await response.json();
            } catch (error) {
                showToast(error?.message ?? 'Ses dosyasi yuklenemedi.', 'error');
                return null;
            }
        }

        function updateSoundPreviewFromUrl(url) {
            updateSoundMedia(url, extractSoundFileName(url));
        }

        function updateSoundMedia(url, fileName) {
            const preview = document.getElementById('newOrderSoundPreview');
            const fileNameNode = document.getElementById('newOrderSoundFileName');
            const previewLabel = document.getElementById('soundPreviewLabel');
            if (preview) {
                preview.src = url ?? '';
            }
            preview?.load?.();
            if (fileNameNode) {
                fileNameNode.textContent = fileName || 'Secili dosya yok';
            }
            if (previewLabel) {
                previewLabel.textContent = fileName
                    ? `${fileName} hazir. Oynat ile test edebilirsiniz.`
                    : 'Kayitli siparis sesi burada test edilir.';
            }
        }

        function extractSoundFileName(url) {
            if (!url) {
                return '';
            }

            if (url.startsWith('data:audio/')) {
                return 'Yerel ses dosyasi';
            }

            try {
                const parsed = new URL(url);
                return parsed.pathname.split('/').filter(Boolean).pop() ?? url;
            } catch {
                return url;
            }
        }

        function hydrateSettingsMediaState() {
            updateSoundMedia(
                document.getElementById('newOrderSoundUrl')?.value ?? '',
                extractSoundFileName(document.getElementById('newOrderSoundUrl')?.value ?? '')
            );
        }

        function afterSectionRender(section) {
            if (section === 'settings') {
                hydrateSettingsMediaState();
                syncSettingsTonePicker('clientInfoBoxType');
                syncSettingsTonePicker('messageType');
            }

            if (section === 'products') {
                syncProductCategoryOptionsFromSection();
            }

            if (section === 'notifications') {
                syncNotificationSectionState();
            }
        }

        function openConfirmModal(title, message, action) {
            pendingConfirmAction = action;
            document.getElementById('confirmTitle').textContent = title;
            document.getElementById('confirmMessage').textContent = message;
            document.getElementById('confirmModal').hidden = false;
            document.getElementById('confirmActionButton').onclick = async () => {
                const actionToRun = pendingConfirmAction;
                closeConfirmModal();
                if (actionToRun) {
                    await actionToRun();
                }
            };
        }

        function closeConfirmModal() {
            document.getElementById('confirmModal').hidden = true;
            pendingConfirmAction = null;
        }

        function dismissConfirmModal(event) {
            if (event.target.id === 'confirmModal') {
                closeConfirmModal();
            }
        }

        function toggleNotificationTray(force) {
            const tray = document.getElementById('notificationTray');
            const shouldOpen = typeof force === 'boolean' ? force : tray.hidden;
            tray.hidden = !shouldOpen;
            if (shouldOpen) {
                recentNotificationItems = recentNotificationItems.map(item => ({ ...item, read: true }));
                unreadNotificationCount = 0;
                updateNotificationBadge();
                renderNotificationTray();
            }
        }

        function updateNotificationBadge() {
            const badge = document.getElementById('notificationBadge');
            if (!badge) {
                return;
            }

            badge.hidden = unreadNotificationCount <= 0;
            badge.textContent = unreadNotificationCount > 99 ? '99+' : unreadNotificationCount.toString();
        }

        function seedNotificationsFromShell() {
            const sources = Array.from(document.querySelectorAll('#notificationSeedSource [data-notification-order]'));
            recentNotificationItems = sources.map(node => ({
                orderId: Number(node.dataset.notificationOrder),
                title: node.dataset.notificationTitle ?? 'Tamamlanan siparis',
                meta: node.dataset.notificationMeta ?? '',
                amount: node.dataset.notificationAmount ?? '',
                status: node.dataset.notificationStatus ?? 'Completed',
                read: true
            }));
            renderNotificationTray();
        }

        function seedNotificationsFromSection() {
            const sources = Array.from(document.querySelectorAll('#sectionHost [data-notification-order]')).slice(0, 10);
            if (sources.length === 0) {
                return;
            }

            const existingById = new Map(recentNotificationItems.map(item => [item.orderId, item]));
            recentNotificationItems = sources.map(node => {
                const orderId = Number(node.dataset.notificationOrder);
                const existing = existingById.get(orderId);
                return {
                    orderId,
                    title: node.dataset.notificationTitle ?? 'Tamamlanan siparis',
                    meta: node.dataset.notificationMeta ?? '',
                    amount: node.dataset.notificationAmount ?? '',
                    status: node.dataset.notificationStatus ?? 'Completed',
                    read: existing?.read ?? true
                };
            });
            renderNotificationTray();
        }

        function renderNotificationTray() {
            const list = document.getElementById('notificationTrayList');
            if (!list) {
                return;
            }

            list.innerHTML = recentNotificationItems.length === 0
                ? '<div class="notification-empty">Henuz tamamlanmis siparis bulunmuyor.</div>'
                : recentNotificationItems.map(item => `
                    <div class="notification-row ${item.read ? '' : 'unread'}" data-status="${item.status ?? 'Completed'}">
                        <div>
                            <strong>${item.title}</strong>
                            <span>${item.meta}</span>
                        </div>
                        <div class="notification-row-actions">
                            <em>${item.amount}</em>
                            <button class="notification-link-button" type="button" onclick="goToNotificationOrder(${item.orderId})">Kayda Git</button>
                        </div>
                    </div>`).join('');
        }

        function syncNotificationSectionState() {
            const sectionItems = Array.from(document.querySelectorAll('#sectionHost [data-notification-order]'));
            const stateMap = new Map(recentNotificationItems.map(item => [item.orderId, item]));
            sectionItems.forEach(item => {
                const orderId = Number(item.dataset.notificationOrder);
                const notification = stateMap.get(orderId);
                item.classList.toggle('unread', notification?.read === false);
            });
        }

        function setSwitchState(button, isOn) {
            if (!button) {
                return;
            }

            button.classList.toggle('on', isOn);
            button.classList.toggle('off', !isOn);
            button.setAttribute('aria-pressed', isOn ? 'true' : 'false');
        }

        async function toggleProductAvailability(productId, button, categoryId, name, price, description, imageUrl) {
            const targetState = button.getAttribute('aria-pressed') !== 'true';
            const payload = {
                id: productId,
                categoryId: categoryId,
                name: name,
                description: description,
                price: Number(price),
                imageUrl: imageUrl,
                isActive: targetState
            };

            const result = await postJson('/dashboard/products', payload, targetState ? 'Urun stokta olarak isaretlendi.' : 'Urun stok disi olarak isaretlendi.', 'Stok durumu guncellenemedi.');
            if (result) {
                setSwitchState(button, targetState);
                await loadSection('products', false, {}, true);
            }
        }

        function queueSearch(value) {
            window.clearTimeout(searchDebounceHandle);
            searchDebounceHandle = window.setTimeout(() => {
                loadSection(getCurrentSection(), true, { search: value, page: 1 }, true);
            }, 260);
        }

        function getSearchValue() {
            return document.getElementById('adminSearchInput')?.value ?? '';
        }

        function appendNotificationFromEvent(order, fallbackStatus = 'Completed') {
            const orderId = Number(order.id ?? order.order?.id ?? 0);
            const rawStatus = order.status ?? order.order?.status ?? fallbackStatus;
            const status = typeof rawStatus === 'string' && rawStatus ? rawStatus : fallbackStatus;
            const title = status === 'Accepted'
                ? `Masa ${order.tableId ?? order.order?.tableId ?? '-'} siparisi onaylandi`
                : status === 'Rejected'
                    ? `Masa ${order.tableId ?? order.order?.tableId ?? '-'} siparisi reddedildi`
                    : `Masa ${order.tableId ?? order.order?.tableId ?? '-'} siparisi tamamlandi`;
            const eventDate = status === 'Rejected'
                ? (order.rejectedAt ?? order.order?.rejectedAt ?? order.createdAt ?? new Date())
                : status === 'Accepted'
                    ? (order.acceptedAt ?? order.order?.acceptedAt ?? order.createdAt ?? new Date())
                    : (order.completedAt ?? order.order?.completedAt ?? order.createdAt ?? new Date());
            const item = {
                orderId,
                title,
                meta: new Date(eventDate).toLocaleString('tr-TR'),
                amount: new Intl.NumberFormat('tr-TR', { style: 'currency', currency: 'TRY', maximumFractionDigits: 0 }).format(order.totalPrice ?? order.order?.totalPrice ?? 0),
                status,
                read: false
            };

            recentNotificationItems = [item, ...recentNotificationItems.filter(existing => existing.orderId !== orderId)].slice(0, 10);
            unreadNotificationCount = recentNotificationItems.filter(notification => !notification.read).length;
            updateNotificationBadge();
            renderNotificationTray();
        }

        function appendNotificationFromOrderCreated(order) {
            const orderId = Number(order.id ?? order.order?.id ?? 0);
            const item = {
                orderId,
                title: `Masa ${order.tableId ?? order.order?.tableId ?? '-'} yeni siparis gonderdi`,
                meta: new Date(order.createdAt ?? order.order?.createdAt ?? new Date()).toLocaleString('tr-TR'),
                amount: new Intl.NumberFormat('tr-TR', { style: 'currency', currency: 'TRY', maximumFractionDigits: 0 }).format(order.totalPrice ?? order.order?.totalPrice ?? 0),
                status: 'Pending',
                read: false
            };

            recentNotificationItems = [item, ...recentNotificationItems.filter(existing => existing.orderId !== orderId)].slice(0, 10);
            unreadNotificationCount = recentNotificationItems.filter(notification => !notification.read).length;
            updateNotificationBadge();
            renderNotificationTray();
        }

        function goToNotificationOrder(orderId) {
            toggleNotificationTray(false);
            loadSection('orders', true, { page: 1, search: String(orderId) }, true);
        }

        async function resolveErrorMessage(response, fallbackMessage) {
            try {
                const payload = await response.json();
                return payload?.message ?? fallbackMessage;
            } catch {
                return fallbackMessage;
            }
        }

        function openDeviceAssignModal(deviceId, hostName, currentTableId) {
            const modal = document.getElementById('deviceAssignModal');
            document.getElementById('deviceAssignDeviceId').value = deviceId;
            document.getElementById('deviceAssignSelectedTable').value = currentTableId ?? '';
            document.getElementById('deviceAssignSubtitle').textContent = `${hostName} icin aktif masalardan birini secin.`;
            deviceAssignPage = 1;
            renderDeviceAssignPage();

            previousOverflow = document.body.style.overflow;
            document.body.style.overflow = 'hidden';
            modal.hidden = false;
        }

        function renderDeviceAssignPage() {
            const seedItems = Array.from(document.querySelectorAll('#deviceTableSeed [data-table-id]'));
            const grid = document.getElementById('deviceAssignGrid');
            const pager = document.getElementById('deviceAssignPager');
            const totalPages = Math.max(1, Math.ceil(seedItems.length / deviceAssignPageSize));
            deviceAssignPage = Math.min(Math.max(deviceAssignPage, 1), totalPages);
            const selected = document.getElementById('deviceAssignSelectedTable').value;
            const pageItems = seedItems.slice((deviceAssignPage - 1) * deviceAssignPageSize, deviceAssignPage * deviceAssignPageSize);

            grid.innerHTML = pageItems.map(item => `
                <button type="button" class="assignment-chip ${item.dataset.tableId === String(selected ?? '') ? 'selected' : ''}" data-table-id="${item.dataset.tableId}" onclick="selectDeviceTable('${item.dataset.tableId}')">
                    <span>${item.dataset.tableName}</span>
                </button>
            `).join('');

            if (pager) {
                pager.innerHTML = `
                    <button class="pagination-button icon-only" type="button" aria-label="Onceki sayfa" ${deviceAssignPage <= 1 ? 'disabled' : ''} onclick="changeDeviceAssignPage(-1)"><span class="material-symbols-outlined">chevron_left</span></button>
                    <span>Sayfa ${deviceAssignPage} / ${totalPages}</span>
                    <button class="pagination-button icon-only" type="button" aria-label="Sonraki sayfa" ${deviceAssignPage >= totalPages ? 'disabled' : ''} onclick="changeDeviceAssignPage(1)"><span class="material-symbols-outlined">chevron_right</span></button>`;
            }
        }

        function changeDeviceAssignPage(delta) {
            deviceAssignPage += delta;
            renderDeviceAssignPage();
        }

        function selectDeviceTable(tableId) {
            document.getElementById('deviceAssignSelectedTable').value = tableId;
            document.querySelectorAll('.assignment-chip').forEach(chip => {
                chip.classList.toggle('selected', chip.dataset.tableId === String(tableId));
            });
        }

        function getAssignedTableSelection() {
            return document.getElementById('deviceAssignSelectedTable')?.value ?? '';
        }

        async function saveDeviceAssignment() {
            const deviceId = document.getElementById('deviceAssignDeviceId').value;
            const tableId = document.getElementById('deviceAssignSelectedTable').value;
            if (!deviceId) {
                return;
            }

            const result = await postJson('/dashboard/devices/assign-table', { deviceId, tableId: tableId ? Number(tableId) : null }, 'Masa eslestirmesi kaydedildi.', 'Masa eslestirmesi kaydedilemedi.');
            if (result) {
                closeDeviceAssignModal();
                await refreshSnapshot(true);
            }
        }

        function closeDeviceAssignModal() {
            document.getElementById('deviceAssignModal').hidden = true;
            document.body.style.overflow = previousOverflow;
        }

        function dismissDeviceAssignModal(event) {
            if (event.target.id === 'deviceAssignModal') {
                closeDeviceAssignModal();
            }
        }

        function showChartTooltip(event) {
            const tooltip = document.getElementById('chartTooltip');
            const target = event.currentTarget;
            const title = target.dataset.tooltipTitle ?? '';
            const content = target.dataset.tooltipContent ?? '';
            tooltip.innerHTML = `<strong>${title}</strong><span>${content.replaceAll('|', '<br/>')}</span>`;
            tooltip.hidden = false;
            const rect = target.getBoundingClientRect();
            const tooltipRect = tooltip.getBoundingClientRect();
            const viewportWidth = document.documentElement.clientWidth;
            const minLeft = window.scrollX + 16;
            const maxLeft = window.scrollX + viewportWidth - tooltipRect.width - 16;
            const centeredLeft = rect.left + window.scrollX + (rect.width / 2) - (tooltipRect.width / 2);
            const top = Math.max(window.scrollY + 16, rect.top + window.scrollY - tooltipRect.height - 14);
            const left = Math.min(Math.max(centeredLeft, minLeft), Math.max(minLeft, maxLeft));
            tooltip.style.left = `${left}px`;
            tooltip.style.top = `${top}px`;
        }

        function hideChartTooltip() {
            document.getElementById('chartTooltip').hidden = true;
        }

        function showToast(message, type) {
            const stack = document.getElementById('toastStack');
            const toast = document.createElement('div');
            toast.className = `toast-item ${type ?? 'info'}`;
            toast.innerHTML = `<span class="material-symbols-outlined">${resolveToastIcon(type)}</span><span>${message}</span>`;
            stack.appendChild(toast);
            requestAnimationFrame(() => toast.classList.add('visible'));
            window.setTimeout(() => {
                toast.classList.remove('visible');
                window.setTimeout(() => toast.remove(), 260);
            }, 3200);
        }

        function resolveToastIcon(type) {
            switch (type) {
                case 'success':
                    return 'check_circle';
                case 'error':
                    return 'error';
                case 'warning':
                    return 'warning';
                default:
                    return 'info';
            }
        }

        function escapeHtml(value) {
            return String(value ?? '')
                .replaceAll('&', '&amp;')
                .replaceAll('<', '&lt;')
                .replaceAll('>', '&gt;')
                .replaceAll('"', '&quot;')
                .replaceAll("'", '&#39;');
        }

        function escapeAttribute(value) {
            return escapeHtml(value);
        }

        function playNewOrderSound() {
            const audio = document.getElementById('newOrderAudio');
            const url = audio?.dataset.soundUrl ?? '';
            const enabled = audio?.dataset.soundEnabled === 'true';
            if (!audio || !enabled || !url) {
                return;
            }

            audio.pause();
            audio.src = url;
            audio.currentTime = 0;
            audio.load();
            audio.play().catch(() => {});
        }

        function playPreviewSound() {
            const preview = document.getElementById('newOrderSoundPreview');
            const url = preview?.currentSrc || preview?.src || document.getElementById('newOrderSoundUrl')?.value || '';
            if (!preview || !url) {
                showToast('Onizleme icin once bir ses dosyasi secin.', 'warning');
                return;
            }

            if (preview.src !== url) {
                preview.src = url;
                preview.load();
            }
            preview.pause();
            preview.currentTime = 0;
            preview.play().catch(() => {});
        }

        function stopPreviewSound() {
            const preview = document.getElementById('newOrderSoundPreview');
            if (!preview) {
                return;
            }

            preview.pause();
            preview.currentTime = 0;
        }
    </script>
}
