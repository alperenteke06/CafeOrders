@model CafeOrders.WebUI.Models.DashboardViewModel
@{
    ViewData["Title"] = "Admin Paneli";
}

<div class="admin-shell">
    <aside class="admin-sidebar">
        <div class="sidebar-brand">
            <h1>@Model.AppSettings.CafeName</h1>
            <p>Gaming Lounge Yonetimi</p>
        </div>

        <nav class="sidebar-nav">
            <button type="button" class="nav-item @(Model.ActiveSection == "dashboard" ? "active" : "")" data-section="dashboard" onclick="loadSection('dashboard', true)">
                <span class="material-symbols-outlined nav-icon">dashboard</span>
                <span>Dashboard</span>
            </button>
            <button type="button" class="nav-item @(Model.ActiveSection == "orders" ? "active" : "")" data-section="orders" onclick="loadSection('orders', true)">
                <span class="material-symbols-outlined nav-icon">receipt_long</span>
                <span>Siparisler</span>
            </button>
            <button type="button" class="nav-item @(Model.ActiveSection == "products" ? "active" : "")" data-section="products" onclick="loadSection('products', true)">
                <span class="material-symbols-outlined nav-icon">restaurant_menu</span>
                <span>Urunler</span>
            </button>
            <button type="button" class="nav-item @(Model.ActiveSection == "categories" ? "active" : "")" data-section="categories" onclick="loadSection('categories', true)">
                <span class="material-symbols-outlined nav-icon">category</span>
                <span>Kategoriler</span>
            </button>
            <button type="button" class="nav-item @(Model.ActiveSection == "devices" ? "active" : "")" data-section="devices" onclick="loadSection('devices', true)">
                <span class="material-symbols-outlined nav-icon">devices</span>
                <span>Cihazlar</span>
            </button>
            <button type="button" class="nav-item @(Model.ActiveSection == "tables" ? "active" : "")" data-section="tables" onclick="loadSection('tables', true)">
                <span class="material-symbols-outlined nav-icon">table_restaurant</span>
                <span>Masalar</span>
            </button>
            <button type="button" class="nav-item @(Model.ActiveSection == "settings" ? "active" : "")" data-section="settings" onclick="loadSection('settings', true)">
                <span class="material-symbols-outlined nav-icon">settings</span>
                <span>Ayarlar</span>
            </button>
            <button type="button" class="nav-item @(Model.ActiveSection == "notifications" ? "active" : "")" data-section="notifications" onclick="loadSection('notifications', true)">
                <span class="material-symbols-outlined nav-icon">notifications</span>
                <span>Bildirimler</span>
            </button>
        </nav>

        <div class="sidebar-footer">
            <div class="profile-card profile-card-menu" tabindex="0">
                <div class="profile-card-main">
                    <div class="profile-avatar">A</div>
                    <div>
                        <div class="profile-name">Admin Profili</div>
                        <div class="profile-role">SUPER YETKILI</div>
                    </div>
                </div>

                <form class="profile-card-actions" method="post" action="/account/logout">
                    @Html.AntiForgeryToken()
                    <button class="action-button action-button-outline profile-logout-button" type="submit">
                        <span class="material-symbols-outlined">logout</span>
                        <span>Cikis Yap</span>
                    </button>
                </form>
            </div>
        </div>
    </aside>

    <div class="admin-content">
        <header class="admin-topbar">
            <div class="topbar-logo topbar-logo-minimal">
                <span class="material-symbols-outlined">admin_panel_settings</span>
            </div>

            <div class="topbar-controls">
                <label id="adminSearchShell" class="topbar-search @((Model.ActiveSection is "dashboard" or "settings") ? "is-hidden" : string.Empty)">
                    <span class="material-symbols-outlined topbar-search-icon">search</span>
                    <input id="adminSearchInput" type="text" value="@Model.SearchQuery" placeholder="Aktif sayfada ara..." oninput="queueSearch(this.value)" />
                </label>

                <button class="icon-chip notification-chip" type="button" aria-label="Bildirimler" onclick="toggleNotificationTray()">
                    <span class="material-symbols-outlined">notifications</span>
                    <span id="notificationBadge" class="notification-badge" hidden>0</span>
                </button>
            </div>
        </header>

        <main class="dashboard-flow">
            <div id="sectionLoading" class="section-loading" hidden>
                <div class="loader-core">
                    <span class="loader-ring"></span>
                    <span class="loader-text">Panel yukleniyor</span>
                </div>
            </div>

            <div id="sectionHost">
                @await Html.PartialAsync($"_{char.ToUpperInvariant(Model.ActiveSection[0])}{Model.ActiveSection[1..]}Section", Model)
            </div>

            <footer class="ops-footer">
                <div class="ops-footer-copy">@Model.AppSettings.CafeName @@ @DateTime.Now.Year Tum Haklari Saklidir.</div>
                <div class="ops-footer-dev">
                    <span>YAZILIM GELISTIRICI</span>
                    <div class="ops-footer-divider"></div>
                    <strong>@Model.AppSettings.AppDeveloperName</strong>
                    <em>@Model.AppSettings.AppDeveloperPhone</em>
                </div>
            </footer>
        </main>
    </div>
</div>

<div id="toastStack" class="toast-stack" aria-live="polite" aria-atomic="true"></div>
<audio id="newOrderAudio"
       preload="none"
       data-sound-enabled="@(Model.AppSettings.EnableNewOrderSound ? "true" : "false")"
       data-sound-url="@Model.AppSettings.NewOrderSoundUrl"></audio>

<div id="notificationSeedSource" hidden>
    @foreach (var item in Model.Notifications)
    {
        <div data-notification-order="@item.OrderId"
             data-notification-title="@item.Title"
             data-notification-meta="@item.Meta"
             data-notification-amount="@item.Amount"
             data-notification-status="@item.Status"></div>
    }
</div>

<div id="notificationTray" class="notification-tray" hidden>
    <div class="notification-tray-head">
        <strong>Son Bildirimler</strong>
        <button class="link-button" type="button" onclick="loadSection('notifications', true); toggleNotificationTray(false)">Tumunu Goster</button>
    </div>
    <div id="notificationTrayList" class="notification-tray-list"></div>
</div>

<div id="confirmModal" class="modal-overlay" hidden onclick="dismissConfirmModal(event)">
    <div class="confirm-modal">
        <div class="confirm-modal-icon">
            <span class="material-symbols-outlined">warning</span>
        </div>
        <h3 id="confirmTitle">Islemi Onayla</h3>
        <p id="confirmMessage">Bu islemi yapmak istediginize emin misiniz?</p>
        <div class="modal-actions">
            <button class="action-button action-button-outline" type="button" onclick="closeConfirmModal()">Iptal</button>
            <button id="confirmActionButton" class="action-button action-button-primary" type="button">Onayla</button>
        </div>
    </div>
</div>

<div id="productEditorModal" class="modal-overlay" hidden onclick="dismissProductEditor(event)">
    <div class="product-modal" role="dialog" aria-modal="true" aria-labelledby="productEditorTitle">
        <div class="product-modal-media">
            <div id="productEditorPreview" class="product-modal-preview visual-burger">
                <img id="productEditorImage" alt="" hidden />
                <div id="productEditorPreviewFallback" class="product-modal-preview-fallback">
                    <span id="productEditorPreviewName">Urun</span>
                </div>
            </div>

            <div class="product-modal-hint">
                <p>Onerilen boyut: 800x800px</p>
                <p>PNG, JPG veya WEBP kullanabilirsiniz</p>
            </div>

            <div id="productImageDropzone" class="product-dropzone" onclick="document.getElementById('productEditorFile').click()"
                 ondragover="handleProductDropOver(event)"
                 ondragleave="handleProductDropLeave(event)"
                 ondrop="handleProductDrop(event)">
                <input id="productEditorFile" type="file" accept="image/*" hidden onchange="handleProductFileChange(event)" />
                <span class="material-symbols-outlined">upload</span>
                <strong>Gorsel Surukle Birak</strong>
                <small>ya da tiklayip dosya secin</small>
            </div>

            <button id="productEditorDeleteButton" class="product-modal-delete" type="button" onclick="deleteProductFromModal()">
                <span class="material-symbols-outlined">delete</span>
                <span>Urunu Sil</span>
            </button>
        </div>

        <div class="product-modal-form">
            <div class="product-modal-head">
                <h3 id="productEditorTitle">Urunu Duzenle</h3>
                <button class="modal-close-button" type="button" aria-label="Kapat" onclick="closeProductEditor()">
                    <span class="material-symbols-outlined">close</span>
                </button>
            </div>

            <input id="productEditorId" type="hidden" />

            <div class="modal-field-block">
                <label class="modal-label" for="productEditorName">Urun Adi</label>
                <input id="productEditorName" class="modal-input" type="text" />
            </div>

            <div class="modal-form-grid product-editor-primary-grid">
                <div class="modal-field-block">
                    <label class="modal-label" for="productEditorCategory">Kategori</label>
                    <div class="modal-picker-shell">
                        <select id="productEditorCategory" class="modal-input modal-select modal-select-native" hidden>
                            @foreach (var category in Model.Catalog.Categories.Where(x => x.IsActive).OrderBy(x => x.SortOrder))
                            {
                                <option value="@category.Id">@category.Name</option>
                            }
                        </select>
                        <button id="productEditorCategoryButton"
                                class="modal-picker-button"
                                type="button"
                                aria-haspopup="listbox"
                                aria-expanded="false"
                                onclick="toggleProductCategoryPicker()">
                            <span id="productEditorCategoryLabel">Kategori secin</span>
                            <span class="material-symbols-outlined modal-select-icon">expand_more</span>
                        </button>
                        <div id="productEditorCategoryMenu" class="modal-picker-menu" hidden role="listbox">
                            @foreach (var category in Model.Catalog.Categories.Where(x => x.IsActive).OrderBy(x => x.SortOrder))
                            {
                                <button class="modal-picker-option"
                                        type="button"
                                        data-category-id="@category.Id"
                                        data-category-name="@category.Name"
                                        onclick="selectProductCategory('@category.Id', '@category.Name')">
                                    <span class="modal-picker-dot"></span>
                                    <span>@category.Name</span>
                                </button>
                            }
                        </div>
                    </div>
                </div>

                <div class="modal-field-block">
                    <label class="modal-label" for="productEditorPrice">Fiyat</label>
                    <div class="modal-price-shell">
                        <input id="productEditorPrice" class="modal-input" type="number" min="0" step="0.01" />
                        <span>TL</span>
                    </div>
                </div>
            </div>

            <div class="modal-field-block">
                <label class="modal-label" for="productEditorImageUrl">Gorsel URL</label>
                <input id="productEditorImageUrl" class="modal-input" type="text" placeholder="https://..." oninput="updateProductPreviewFromUrl(this.value)" />
            </div>

            <div class="modal-stock-row">
                <div class="modal-stock-copy">
                    <span class="material-symbols-outlined">inventory_2</span>
                    <strong>Stokta Var</strong>
                </div>
                <button id="productEditorStock" class="switch on" type="button" aria-pressed="true" onclick="toggleProductStock(this)"></button>
            </div>

            <div class="modal-field-block">
                <label class="modal-label" for="productEditorDescription">Aciklama</label>
                <textarea id="productEditorDescription" class="modal-input modal-textarea" rows="4"></textarea>
            </div>

            <div class="modal-actions">
                <button class="action-button action-button-outline" type="button" onclick="closeProductEditor()">Iptal</button>
                <button class="action-button action-button-primary" type="button" onclick="saveProduct()">Degisiklikleri Kaydet</button>
            </div>
        </div>
    </div>
</div>

<div id="quickPriceModal" class="modal-overlay" hidden onclick="dismissQuickPriceModal(event)">
    <div class="quick-price-modal" role="dialog" aria-modal="true" aria-labelledby="quickPriceTitle">
        <div class="quick-price-head">
            <div>
                <span class="quick-price-eyebrow">Toplu Fiyat Guncelleme</span>
                <h3 id="quickPriceTitle">Hizli Fiyat Girisi</h3>
                <p id="quickPriceSubtitle">Aktif filtreye gore listelenen urunlerin fiyatlarini tek ekrandan duzenleyin.</p>
            </div>
            <button class="modal-close-button" type="button" aria-label="Kapat" onclick="closeQuickPriceModal()">
                <span class="material-symbols-outlined">close</span>
            </button>
        </div>

        <div class="quick-price-summary">
            <div class="quick-price-summary-card">
                <span class="material-symbols-outlined">inventory_2</span>
                <div>
                    <strong id="quickPriceCount">0 urun</strong>
                    <small>Secili filtredeki urunler listeleniyor</small>
                </div>
            </div>
            <div class="quick-price-summary-card accent">
                <span class="material-symbols-outlined">tune</span>
                <div>
                    <strong>Canli filtreye bagli</strong>
                    <small id="quickPriceFilterLabel">Tum urunler uzerinde calisiyorsunuz</small>
                </div>
            </div>
        </div>

        <div class="quick-price-shell">
            <div class="quick-price-table quick-price-table-head" aria-hidden="true">
                <div>Urun Adi</div>
                <div>Kategori</div>
                <div>Fiyat</div>
            </div>
            <div id="quickPriceRows" class="quick-price-rows"></div>
            <div id="quickPriceEmpty" class="quick-price-empty" hidden>
                <span class="material-symbols-outlined">table_rows_narrow</span>
                <strong>Filtreye uygun urun bulunamadi</strong>
                <p>Arama veya kategori secimini degistirip tekrar deneyin.</p>
            </div>
        </div>

        <div class="modal-actions quick-price-actions">
            <button class="action-button action-button-outline" type="button" onclick="closeQuickPriceModal()">Iptal</button>
            <button id="quickPriceSaveButton" class="action-button action-button-primary" type="button" onclick="saveQuickPriceUpdates()">Fiyatlari Kaydet</button>
        </div>
    </div>
</div>

<div id="deviceAssignModal" class="modal-overlay" hidden onclick="dismissDeviceAssignModal(event)">
    <div class="assignment-modal" role="dialog" aria-modal="true" aria-labelledby="deviceAssignTitle">
        <div class="product-modal-head">
            <div>
                <h3 id="deviceAssignTitle">Cihaza Masa Ata</h3>
                <p id="deviceAssignSubtitle">Kayitli masalardan birini secin.</p>
            </div>
            <button class="modal-close-button" type="button" aria-label="Kapat" onclick="closeDeviceAssignModal()">
                <span class="material-symbols-outlined">close</span>
            </button>
        </div>

        <input id="deviceAssignDeviceId" type="hidden" />
        <input id="deviceAssignSelectedTable" type="hidden" />

        <div id="deviceAssignGrid" class="assignment-grid"></div>
        <div id="deviceAssignPager" class="pagination-bar assignment-pager"></div>

        <div class="modal-actions sticky-actions">
            <button class="action-button action-button-outline" type="button" onclick="closeDeviceAssignModal()">Iptal</button>
            <button class="action-button action-button-primary" type="button" onclick="saveDeviceAssignment()">Masa Atamasini Kaydet</button>
        </div>
    </div>
</div>

<div id="chartTooltip" class="chart-tooltip" hidden></div>

@section Scripts {
    <script>
        let previousOverflow = '';
        let recentNotificationItems = [];
        let unreadNotificationCount = 0;
        let pendingConfirmAction = null;
        let searchDebounceHandle = null;
        let hubConnection = null;
        let hubReconnectTimer = null;
        let isHubStarting = false;
        let deviceAssignPage = 1;
        let snapshotRefreshInFlight = false;
        let snapshotRefreshQueued = false;
        let quickPriceRowsState = [];
        const deviceAssignPageSize = 50;

        document.addEventListener('DOMContentLoaded', () => {
            syncSearchVisibility(getCurrentSection());
            syncSearchInputFromUrl();
            seedNotificationsFromShell();
            hydrateSettingsMediaState();
            syncSettingsTonePicker('clientInfoBoxType');
            syncSettingsTonePicker('messageType');
            syncProductCategoryOptionsFromSection();
            startAdminHub();
            document.addEventListener('click', handleGlobalUiClick);
        });

        async function loadSection(section, pushHistory, overrides = {}, silent = false) {
            if (!silent) {
                setSectionLoading(true);
            }

            const url = buildSectionUrl(section, overrides);
            const controller = new AbortController();
            const timeoutId = window.setTimeout(() => controller.abort(), 10000);
            try {
                const response = await fetch(url.fetchUrl, {
                    headers: { 'X-Requested-With': 'XMLHttpRequest' },
                    signal: controller.signal
                });

                if (!response.ok) {
                    showToast(await resolveErrorMessage(response, 'Panel yuklenemedi.'), 'error');
                    return;
                }

                document.getElementById('sectionHost').innerHTML = await response.text();
                document.querySelectorAll('.sidebar-nav .nav-item').forEach(button => {
                    button.classList.toggle('active', button.dataset.section === section);
                });
                syncSearchVisibility(section);
                syncSearchInputFromUrl(url.params);
                seedNotificationsFromSection();
                afterSectionRender(section);

                if (pushHistory) {
                    window.history.pushState({ section }, '', url.browserUrl);
                }
            } catch {
                if (!silent) {
                    showToast('Panel yaniti zaman asimina ugradi.', 'warning');
                }
            } finally {
                window.clearTimeout(timeoutId);
                if (!silent) {
                    setSectionLoading(false);
                }
            }
        }

        function setSectionLoading(isVisible) {
            const host = document.getElementById('sectionHost');
            const loading = document.getElementById('sectionLoading');
            host.classList.toggle('is-loading', isVisible);
            loading.hidden = !isVisible;
        }

        window.addEventListener('popstate', async event => {
            const section = event.state?.section ?? new URL(window.location.href).searchParams.get('section') ?? 'dashboard';
            await loadSection(section, false, {}, true);
        });

        async function startAdminHub() {
            if (!window.signalR || isHubStarting) {
                return;
            }

            isHubStarting = true;
            const hubUrls = getAdminHubUrls();
            for (const url of hubUrls) {
                const connected = await connectHub(url);
                if (connected) {
                    isHubStarting = false;
                    return;
                }
            }

            isHubStarting = false;
        }

        function getAdminHubUrls() {
            const host = window.location.hostname;
            return [
                `https://${host}:7001/hubs/cafe`,
                `http://${host}:5001/hubs/cafe`,
                'https://localhost:7001/hubs/cafe',
                'http://localhost:5001/hubs/cafe',
                'https://127.0.0.1:7001/hubs/cafe',
                'http://127.0.0.1:5001/hubs/cafe'
            ];
        }

        async function connectHub(url) {
            if (hubConnection) {
                try {
                    await hubConnection.stop();
                } catch {
                }
            }

            hubConnection = new signalR.HubConnectionBuilder()
                .withUrl(url)
                .withAutomaticReconnect()
                .build();

            registerHubHandlers(hubConnection);

            try {
                await hubConnection.start();
                await hubConnection.invoke('JoinAdminChannel');
                hubConnection.onreconnected(async () => {
                    await hubConnection.invoke('JoinAdminChannel');
                    requestSnapshotRefresh();
                });
                hubConnection.onclose(async () => {
                    if (hubReconnectTimer) {
                        window.clearTimeout(hubReconnectTimer);
                    }
                    hubReconnectTimer = window.setTimeout(() => startAdminHub(), 2500);
                });
                return true;
            } catch {
                return false;
            }
        }

        function registerHubHandlers(connection) {
            connection.on('OrderCreated', order => {
                showToast('Yeni siparis geldi.', 'info');
                appendNotificationFromOrderCreated(order);
                playNewOrderSound();
                requestSnapshotRefresh();
            });
            connection.on('OrderAccepted', order => {
                showToast(`Masa ${order.order?.tableId ?? order.tableId ?? ''} siparisi onaylandi.`, 'success');
                appendNotificationFromEvent(order, 'Accepted');
                requestSnapshotRefresh();
            });
            connection.on('OrderRejected', order => {
                showToast('Bir siparis reddedildi.', 'warning');
                appendNotificationFromEvent(order, 'Rejected');
                requestSnapshotRefresh();
            });
            connection.on('OrderCompleted', order => {
                showToast('Bir siparis tamamlandi.', 'success');
                appendNotificationFromEvent(order, 'Completed');
                requestSnapshotRefresh();
            });
            connection.on('DeviceApproved', () => {
                showToast('Bir cihaz onaylandi.', 'success');
                requestSnapshotRefresh();
            });
            connection.on('DeviceRejected', () => {
                showToast('Bekleyen cihaz talebi reddedildi.', 'warning');
                requestSnapshotRefresh();
            });
            connection.on('DeviceMapped', () => {
                showToast('Masa ve cihaz eslestirmesi guncellendi.', 'info');
                requestSnapshotRefresh();
            });
            connection.on('DevicesUpdated', () => {
                requestSnapshotRefresh();
            });
            connection.on('CatalogUpdated', () => {
                requestSnapshotRefresh();
            });
            connection.on('TablesUpdated', () => {
                requestSnapshotRefresh();
            });
            connection.on('AppSettingsUpdated', () => {
                refreshShellPresentation();
                requestSnapshotRefresh();
            });
            connection.on('InfoMessageUpdated', () => {
                refreshShellPresentation();
                requestSnapshotRefresh();
            });
        }

        function getCurrentSection() {
            return document.querySelector('.sidebar-nav .nav-item.active')?.dataset.section ?? 'dashboard';
        }

        function syncSearchVisibility(section) {
            const shell = document.getElementById('adminSearchShell');
            const visibleSections = ['orders', 'products', 'categories', 'devices', 'tables', 'notifications'];
            shell?.classList.toggle('is-hidden', !visibleSections.includes(section));
        }

        function syncSearchInputFromUrl(params) {
            const urlParams = params ?? new URL(window.location.href).searchParams;
            const input = document.getElementById('adminSearchInput');
            if (input) {
                input.value = urlParams.get('search') ?? '';
            }
        }

        function buildSectionUrl(section, overrides = {}) {
            const url = new URL(window.location.href);
            url.searchParams.set('section', section);

            const keys = ['range', 'search', 'category', 'page'];
            for (const key of keys) {
                if (Object.prototype.hasOwnProperty.call(overrides, key)) {
                    const value = overrides[key];
                    if (value === null || value === undefined || value === '' || value === 'all' && key !== 'category') {
                        url.searchParams.delete(key);
                    } else {
                        url.searchParams.set(key, String(value));
                    }
                }
            }

            if (!url.searchParams.has('range')) {
                url.searchParams.set('range', '1g');
            }

            if ((overrides.search ?? url.searchParams.get('search') ?? '') === '') {
                url.searchParams.delete('search');
            }

            if ((overrides.category ?? url.searchParams.get('category') ?? 'all') === 'all') {
                url.searchParams.delete('category');
            }

            if (String(overrides.page ?? url.searchParams.get('page') ?? '1') === '1') {
                url.searchParams.delete('page');
            }

            return {
                params: url.searchParams,
                browserUrl: `${url.pathname}?${url.searchParams.toString()}`,
                fetchUrl: `/dashboard/section/${section}?${url.searchParams.toString()}`
            };
        }

        async function refreshSnapshot(silent = true) {
            await loadSection(getCurrentSection(), false, {}, silent);
        }

        async function refreshShellPresentation() {
            try {
                const response = await fetch('/dashboard/presentation', {
                    headers: { 'X-Requested-With': 'XMLHttpRequest' }
                });
                if (!response.ok) {
                    return;
                }

                applyPresentationState(await response.json());
            } catch {
            }
        }

        function applyPresentationState(payload) {
            if (!payload) {
                return;
            }

            const brandTitle = document.querySelector('.sidebar-brand h1');
            if (brandTitle) {
                brandTitle.textContent = payload.cafeName ?? brandTitle.textContent;
            }

            const footerCopy = document.querySelector('.ops-footer-copy');
            if (footerCopy) {
                footerCopy.textContent = payload.footerCopyright ?? footerCopy.textContent;
            }

            const developerName = document.querySelector('.ops-footer-dev strong');
            if (developerName) {
                developerName.textContent = payload.appDeveloperName ?? developerName.textContent;
            }

            const developerPhone = document.querySelector('.ops-footer-dev em');
            if (developerPhone) {
                developerPhone.textContent = payload.appDeveloperPhone ?? developerPhone.textContent;
            }

            const audio = document.getElementById('newOrderAudio');
            if (audio) {
                audio.dataset.soundEnabled = payload.soundEnabled ? 'true' : 'false';
                audio.dataset.soundUrl = payload.soundUrl ?? '';
            }
        }

        function requestSnapshotRefresh() {
            if (snapshotRefreshInFlight) {
                snapshotRefreshQueued = true;
                return;
            }

            snapshotRefreshInFlight = true;
            window.setTimeout(async () => {
                try {
                    await refreshSnapshot(true);
                } finally {
                    snapshotRefreshInFlight = false;
                    if (snapshotRefreshQueued) {
                        snapshotRefreshQueued = false;
                        requestSnapshotRefresh();
                    }
                }
            }, 80);
        }

        async function requestJson(url, options, successMessage, errorMessage) {
            try {
                const response = await fetch(url, {
                    headers: { 'Content-Type': 'application/json', ...(options?.headers ?? {}) },
                    ...options
                });

                if (!response.ok) {
                    throw new Error(await resolveErrorMessage(response, errorMessage));
                }

                if (successMessage) {
                    showToast(successMessage, 'success');
                }

                return response.status === 204 ? null : await response.json();
            } catch (error) {
                showToast(error?.message ?? errorMessage, 'error');
                return null;
            }
        }

        async function postJson(url, payload, successMessage, errorMessage) {
            return await requestJson(url, {
                method: 'POST',
                body: JSON.stringify(payload)
            }, successMessage, errorMessage);
        }

        async function putJson(url, payload, successMessage, errorMessage) {
            return await requestJson(url, {
                method: 'PUT',
                body: JSON.stringify(payload)
            }, successMessage, errorMessage);
        }

        async function deleteRequest(url, successMessage, errorMessage) {
            try {
                const response = await fetch(url, { method: 'DELETE' });
                if (!response.ok) {
                    throw new Error(await resolveErrorMessage(response, errorMessage));
                }

                if (successMessage) {
                    showToast(successMessage, 'success');
                }

                return true;
            } catch (error) {
                showToast(error?.message ?? errorMessage, 'error');
                return false;
            }
        }

